# Copie para a Vercel (Settings → Environment Variables) ou para .env.local (nunca commite segredos).
# Nomes exatos — prefixo SENTINELA_ conforme .cursor/rules e código.

SENTINELA_NEXT_PUBLIC_SUPABASE_URL=
SENTINELA_NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Criptografia (servidor prefer SENTINELA_ENCRYPTION_KEY; fallback no cliente usa NEXT_PUBLIC)
SENTINELA_ENCRYPTION_KEY=
# Opcional se precisar no bundle cliente:
# SENTINELA_NEXT_PUBLIC_ENCRYPTION_KEY=

SENTINELA_GEMINI_KEY=
SENTINELA_OPENAI_KEY=

# Opcionais
# SENTINELA_MAX_UPLOAD_BYTES=
# SENTINELA_BYPASS_LIMIT=
# SENTINELA_FREE_SCAN_LIMIT=
# SENTINELA_MAX_PDF_PAGES=

# Versão na UI: na Vercel costuma vir do commit (next.config); local pode ignorar
# NEXT_PUBLIC_APP_VERSION=
